# =============================================================================
# FinBot v6 environment template
# =============================================================================
# Скопируй этот файл в .env, заполни значения, дальше `supabase secrets set --env-file .env`.
# .env должен быть в .gitignore (НИКОГДА не коммитить его).

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_TELEGRAM_ID=

# === Anthropic ===
ANTHROPIC_API_KEY=
# Snapshot IDs закреплены в Supabase secrets, не в коде. См. SPEC §7.1.
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_VISION=claude-sonnet-4-6
ANTHROPIC_DAILY_BUDGET_USD=1.00
ANTHROPIC_DAILY_BUDGET_USD_PER_USER=0.30

# === Groq (Whisper STT) ===
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3-turbo
WHISPER_LANGUAGES_WHITELIST=ru,uk,pl,en
WHISPER_MAX_VOICE_DURATION_SEC=300

# === Image processing (через magick-wasm, не sharp/heic-convert) ===
IMAGE_MAX_DIMENSION=1920
IMAGE_JPEG_QUALITY=85
PHOTO_RETENTION_DAYS=90

# === Misc business config ===
DEFAULT_CURRENCY=PLN
DEFAULT_TIMEZONE=Europe/Warsaw
HIGH_AMOUNT_THRESHOLD_PLN=200
CONFIRMATION_TIMEOUT_SEC=60
UNDO_WINDOW_MINUTES=10

# === Cron security ===
# Генерируется автоматически в bootstrap: openssl rand -hex 32
CRON_SECRET=

# === GitHub (для backup upload в Releases) ===
GITHUB_TOKEN=
GITHUB_REPO=
# age public key (формат age1...). Private хранится в 1Password пользователя.
BACKUP_ENCRYPTION_KEY=

# === Supabase инфраструктурные (нужны для GitHub Actions secrets, НЕ в Edge Functions) ===
# SUPABASE_URL и SUPABASE_SERVICE_ROLE_KEY автоматически инжектируются в Edge Functions.
# Эти ниже идут в `gh secret set` для CI/CD.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
# Для локального restore.ts (НЕ в Supabase secrets, только локально).
SUPABASE_DB_URL=
